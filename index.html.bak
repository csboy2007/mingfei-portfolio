	<!-- Main JS (Do not remove) -->
	<script src="js\main.js"></script>
	<script>
	// 气泡动画代码
	class BubbleAnimation {
		constructor() {
			this.container = document.querySelector('.bubble-container');
			this.bubbles = [];
			this.isRunning = false;
		}

		start() {
			this.isRunning = true;
			this.createBubbles();
		}

		stop() {
			this.isRunning = false;
			this.bubbles.forEach(bubble => {
				if (bubble.element && bubble.element.parentNode) {
					bubble.element.remove();
				}
			});
			this.bubbles = [];
		}

		createBubbles() {
			if (!this.isRunning) return;

			// 创建新气泡
			const bubble = this.createBubble();
			this.bubbles.push(bubble);

			// 设置下一个气泡的创建时间
			setTimeout(() => {
				this.createBubbles();
			}, Math.random() * 1000 + 500); // 0.5-1.5秒随机间隔（更频繁）
		}

		createBubble() {
			const bubble = document.createElement('div');
			bubble.className = 'bubble';
			
			// 随机选择气泡类型 - 星星占90%，方块占10%
			const rand = Math.random();
			let randomType;
			if (rand < 0.9) {
				// 90% 概率是星星
				randomType = 'star';
			} else if (rand < 0.95) {
				// 5% 概率是紫色方块
				randomType = 'purple';
			} else {
				// 5% 概率是绿色方块
				randomType = 'green';
			}
			bubble.classList.add(randomType);

			// 随机位置
			const x = Math.random() * 100;
			const y = Math.random() * 100;
			bubble.style.left = x + '%';
			bubble.style.top = y + '%';

			// 随机大小
			const size = Math.random() * 20 + 10;
			bubble.style.width = size + 'px';
			bubble.style.height = size + 'px';

			this.container.appendChild(bubble);

			// 动画结束后移除气泡
			setTimeout(() => {
				if (bubble.parentNode) {
					bubble.remove();
				}
				this.bubbles = this.bubbles.filter(b => b.element !== bubble);
			}, 8000); // 8秒存在时间（更持久）

			return { element: bubble, type: randomType };
		}
	}

	// 初始化气泡动画
	const bubbleAnimation = new BubbleAnimation();

	// 动画序列控制
	document.addEventListener('DOMContentLoaded', function() {
		const mainTitle = document.getElementById('main-title');
		const genaiText = document.getElementById('genai-text');

		// 立即开始动画，移除延迟
		try {
			console.log('Starting animations...');
			
		// 启动气泡动画
		bubbleAnimation.start();
		console.log('Bubble animation started');
		
		// 给Mingfei Bi和GENAI文本都启动渐变动画
		mainTitle.classList.add('animated');
		genaiText.classList.add('animated');
		console.log('Gradient animation started for both title and GENAI text');
		
		// 验证动画类是否添加成功
		console.log('Main title classes:', mainTitle.className);
		console.log('GENAI text classes:', genaiText.className);
			
		} catch (error) {
			console.error('Animation initialization error:', error);
		}

		// 清理函数
		window.addEventListener('beforeunload', () => {
			bubbleAnimation.stop();
		});
		
		// Glass Box Card 滚动固定效果 - 渐进式挤压淡入动画
		// 所有project sections的配置
		const projectSections = [
			{ sectionId: 'glass-box-pattern', topId: 'glass-box-top' },
			{ sectionId: 'agentcore', topId: 'agentcore-top' },
			{ sectionId: 'demoportal', topId: 'demoportal-top' },
			{ sectionId: 'vawl1', topId: 'vawl1-top' },
			{ sectionId: 'vawl2', topId: 'vawl2-top' },
			{ sectionId: 'cfaia', topId: 'cfaia-top' },
			{ sectionId: 'dbcaps', topId: 'dbcaps-top' },
			{ sectionId: 'sidekck', topId: 'sidekck-top' }
		];
		
		const header = document.getElementById('fh5co-header');
		
		function handleScroll() {
			const headerHeight = header.offsetHeight || 70;
			const headerBottom = headerHeight; // top nav的下沿位置（相对于视口）
			
			let activeTopCard = null;
			let maxProgress = -1;
			
			// 先遍历所有sections，找出应该显示的那个top card
			projectSections.forEach(config => {
				const section = document.getElementById(config.sectionId);
				if (!section) return;
				
				const cardRect = section.getBoundingClientRect();
				const cardTop = cardRect.top;
				const cardBottom = cardRect.bottom;
				const cardHeight = cardRect.height;
				
				// 如果这个section已经开始进入动画范围
				if (cardTop <= headerBottom && cardBottom > headerBottom) {
					const progress = (headerBottom - cardTop) / cardHeight;
					if (progress > maxProgress) {
						maxProgress = progress;
						activeTopCard = config.topId;
					}
				} else if (cardBottom <= headerBottom) {
					// 如果这个section已经完全滚过，选择最后一个
					if (maxProgress < 1) {
						maxProgress = 1;
						activeTopCard = config.topId;
					}
				}
			});
			
			// 然后更新所有top cards的显示状态
			projectSections.forEach(config => {
				const topCard = document.getElementById(config.topId);
				if (!topCard) return;
				
				if (config.topId === activeTopCard) {
					// 这是应该显示的card，计算其opacity
					const section = document.getElementById(config.sectionId);
					const cardRect = section.getBoundingClientRect();
					const cardTop = cardRect.top;
					const cardBottom = cardRect.bottom;
					const cardHeight = cardRect.height;
					
					if (cardBottom > headerBottom) {
						// 还在动画过程中
						const progress = (headerBottom - cardTop) / cardHeight;
						const opacity = Math.max(0, Math.min(1, progress));
						topCard.style.opacity = opacity;
						topCard.style.pointerEvents = opacity > 0.1 ? 'auto' : 'none';
					} else {
						// 完全显示
						topCard.style.opacity = '1';
						topCard.style.pointerEvents = 'auto';
					}
				} else {
					// 隐藏其他cards
					topCard.style.opacity = '0';
					topCard.style.pointerEvents = 'none';
				}
			});
		}
		
		window.addEventListener('scroll', handleScroll);
		// 初始检查
		handleScroll();
	});
	</script>

	<!-- NDA Modal -->
	<div id="ndaModal" class="nda-modal">
		<div class="nda-modal-content">
			<span class="nda-close">&times;</span>
			<div class="nda-header">
				<h3>Non-Disclosure Agreement</h3>
			</div>
			<div class="nda-body">
				<p class="project-text">Certain aspects of this project are protected under a Non-Disclosure Agreement and cannot be shared publicly.</p>
				<p class="project-text">This work involved the redesign of a large-scale internal AWS tool for global field teams.</p>
				<p class="project-text">If you are interested in learning more, please contact me to arrange an NDA-compliant discussion.</p>
			</div>
			<div class="nda-footer">
				<button class="btn btn-primary" onclick="closeNDAModal()">I Understand</button>
			</div>
		</div>
	</div>

	<style>
		/* NDA Modal - 只保留必要的布局样式，使用网站已有的字体和颜色样式 */
		.nda-modal {
			display: none;
			position: fixed;
			z-index: 9999;
			left: 0;
			top: 0;
			width: 100%;
			height: 100%;
			background-color: rgba(0, 0, 0, 0.7);
			backdrop-filter: blur(5px);
		}

		.nda-modal-content {
			background-color: white;
			margin: 5% auto;
			padding: 0;
			border-radius: 8px;
			width: 90%;
			max-width: 750px;
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
			animation: modalSlideIn 0.3s ease-out;
		}

		@keyframes modalSlideIn {
			from {
				opacity: 0;
				transform: translateY(-50px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.nda-header {
			background: white;
			color: rgb(36, 36, 36);
			padding: 40px 0 40px 0;
			border-radius: 8px 8px 0 0;
			text-align: center;
		}

		.nda-header h3 {
			position: relative;
			font-family: "Monda","PT Sans", Arial, sans-serif;
			font-weight: bold;
			font-size: 30px;
			color: rgb(36, 36, 36);
			margin: 0;
		}

		.nda-body {
			padding: 30px 60px;
			text-align: left;
		}

		.nda-footer {
			padding: 20px 25px 25px;
			text-align: center;
			border-top: 1px solid #eee;
		}

		.nda-close {
			color: rgb(36, 36, 36);
			float: right;
			font-size: 28px;
			font-weight: bold;
			line-height: 1;
			cursor: pointer;
			position: absolute;
			right: 20px;
			top: 20px;
			transition: opacity 0.2s;
		}

		.nda-close:hover,
		.nda-close:focus {
			opacity: 0.7;
		}

		/* 响应式设计 */
		@media (max-width: 768px) {
			.nda-modal-content {
				width: 95%;
				margin: 10% auto;
			}
		}
	</style>

	<script>
		// NDA Modal Functionality
		function openNDAModal(project) {
			document.getElementById('ndaModal').style.display = 'block';
			document.body.style.overflow = 'hidden'; // Prevent background scrolling
		}

		function closeNDAModal() {
			document.getElementById('ndaModal').style.display = 'none';
			document.body.style.overflow = 'auto'; // Restore scrolling
		}

		// Close modal when clicking outside of it
		window.onclick = function(event) {
			const modal = document.getElementById('ndaModal');
			if (event.target === modal) {
				closeNDAModal();
			}
		}

		// Close modal with escape key
		document.addEventListener('keydown', function(event) {
			if (event.key === 'Escape') {
				closeNDAModal();
			}
		});

		// Add click event listeners to all NDA modal triggers
		document.addEventListener('DOMContentLoaded', function() {
			const modalTriggers = document.querySelectorAll('.nda-modal-trigger');
			
			modalTriggers.forEach(trigger => {
				trigger.addEventListener('click', function(e) {
					e.preventDefault();
					const project = this.getAttribute('data-project');
					openNDAModal(project);
				});
			});

			// Close button event listener
			const closeBtn = document.querySelector('.nda-close');
			if (closeBtn) {
				closeBtn.addEventListener('click', closeNDAModal);
			}
		});
	</script>
		
	</body>
</html>


